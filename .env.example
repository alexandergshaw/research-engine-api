# ---------------------------------------------------------------------------
# Research Engine API — environment configuration (stateless; no data storage)
# Copy to .env and fill in. Everything has a sane default; the API runs with
# NONE of these set (open auth, in-memory cache, lower upstream rate limits).
# ---------------------------------------------------------------------------

# Flask
FLASK_APP=wsgi:app
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# Auth: comma-separated accepted API keys (X-API-Key). Empty => open (no key).
# Generate one with:  flask --app wsgi genkey
API_KEYS=

# Polite identification — REQUIRED by Wikipedia & SEC. Put a real contact.
USER_AGENT=research-engine-api/0.1 (+you@example.com)

# Connectors to skip (e.g. the bulk MITRE dataset on serverless/Vercel).
# DISABLED_CONNECTORS=mitre_attack

# CORS allow-list (csv) — only needed when the console calls the API cross-origin.
# CORS_ORIGINS=http://localhost:5050

# Best-effort per-key rate limit (in-memory; no external store).
RATELIMIT_DEFAULT=120/minute

# Outbound HTTP behaviour (the resilience knobs).
HTTP_TIMEOUT=8.0            # per-request timeout (seconds)
FANOUT_DEADLINE=12.0        # wall-clock budget for a whole multi-source request
MAX_CONNECTORS_PER_INTENT=4
HTTP_MAX_RETRIES=3
BREAKER_FAIL_MAX=5
BREAKER_RESET_TIMEOUT=60

# ---------------------------------------------------------------------------
# Optional SOURCE credentials (raise upstream quotas; engine degrades without).
# ---------------------------------------------------------------------------
# STACKEXCHANGE_KEY=
# GITHUB_TOKEN=
# NVD_API_KEY=
# SEMANTIC_SCHOLAR_KEY=
