# ---------------------------------------------------------------------------
# Research Engine API — environment configuration
# Copy to .env and fill in. Everything here has a sane default; the engine
# runs with NONE of these set (it just uses lower upstream rate limits and
# in-memory cache/rate-limiting).
# ---------------------------------------------------------------------------

# Flask
FLASK_APP=wsgi:app
FLASK_DEBUG=1
SECRET_KEY=change-me-in-production

# Persistence (tenants, API keys, usage logs). SQLite by default.
DATABASE_URL=sqlite:///research_engine.db

# Cache + rate-limit backing store. Leave REDIS_URL unset to use in-memory
# (fine for local dev; use Redis in production).
# REDIS_URL=redis://localhost:6379/0
CACHE_DEFAULT_TIMEOUT=300

# Default rate limit applied per API key when a tenant has no explicit plan.
RATELIMIT_DEFAULT=120/minute

# Outbound HTTP behaviour (the resilience knobs).
HTTP_TIMEOUT=8.0            # per-request timeout (seconds)
FANOUT_DEADLINE=12.0        # wall-clock budget for a whole multi-source request
MAX_CONNECTORS_PER_INTENT=4
HTTP_MAX_RETRIES=3
BREAKER_FAIL_MAX=5
BREAKER_RESET_TIMEOUT=60

# Polite identification — REQUIRED by Wikipedia & SEC EDGAR. Put a real contact.
USER_AGENT=research-engine-api/0.1 (+you@example.com)

# ---------------------------------------------------------------------------
# Optional SOURCE credentials (raise upstream quotas; engine degrades without).
# These are credentials for the data SOURCES, distinct from tenant API keys.
# ---------------------------------------------------------------------------
# STACKEXCHANGE_KEY=
# GITHUB_TOKEN=
# NVD_API_KEY=
# SEMANTIC_SCHOLAR_KEY=
# ONET_USERNAME=
# ONET_PASSWORD=
